# Скопируйте этот файл в .env и подставьте свои значения:
#   cp .env.example .env

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=users

# Секрет для подписи JWT-токенов — замените на свою случайную строку
PRIVATE_KEY=change-me-to-random-secret

# Нужны только для запуска БЕЗ Docker (docker-compose задаёт их сам)
PORT=8000
POSTGRES_HOST=localhost
POSTGRES_PORT=5432